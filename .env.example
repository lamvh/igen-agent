# Sao chép file này thành .env.local rồi điền giá trị.
# .env.local đã được .gitignore — KHÔNG commit key thật.

# Database — libSQL/SQLite.
# - Local dev: để nguyên file local.
# - Deploy (Vercel/Turso): đổi sang URL libsql + điền TURSO_AUTH_TOKEN.
DATABASE_URL=file:./local.db
# Bỏ trống khi chạy local file; điền khi dùng Turso (libsql://<db>.turso.io).
TURSO_AUTH_TOKEN=

# Claude (Anthropic) — sinh ý tưởng + caption. Lấy tại https://console.anthropic.com
# Để trống thì app vẫn chạy, chỉ tắt sinh tự động.
ANTHROPIC_API_KEY=

# Gemini (Google) — sinh ảnh AI (sắp có). Lấy tại https://aistudio.google.com
GEMINI_API_KEY=
